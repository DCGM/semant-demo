# ── Git repository ────────────────────────────────────────────
REPO=https://github.com/DCGM/semant-demo.git
BRANCH=main

BACKEND_URL=https://demo.semant.cz

DOMAIN=demo.semant.cz

WEAVIATE_HOST=weaviate
WEAVIATE_REST_PORT=8080
WEAVIATE_GRPC_PORT=50051

EMBEDDING_SERVICE_HOST=embedding-service
EMBEDDING_SERVICE_PORT=8001
GPU_DEVICE=0
GEMMA_MODEL=BAAI/bge-multilingual-gemma2

# ── LLM providers ───────────────────────────────────────────
OLLAMA_URLS=http://localhost:11434
OLLAMA_MODEL=gemma3:12b
OPENAI_API_KEY=
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro
MODEL_TEMPERATURE=0.0

# ── LangChain / LangSmith tracing (optional) ────────────────
LANGCHAIN_API_KEY=

# ── Application ──────────────────────────────────────────────
ALLOWED_ORIGIN=https://demo.semant.cz
PORT=8000
STATIC_PATH=./static
